# AnimeVerse — Frontend (Next.js)
# Copy to .env.local and adjust values.
# cp .env.example .env.local

# Backend API base URL (required when using auth/sync)
NEXT_PUBLIC_API_URL=http://localhost:3001

# Public site URL (SEO, Open Graph)
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Google OAuth — optional; enables Google Sign-In when set
# Must match GOOGLE_CLIENT_ID on the backend
NEXT_PUBLIC_GOOGLE_CLIENT_ID=

# MyAnimeList API — optional; falls back to Jikan when unset
NEXT_PUBLIC_MAL_CLIENT_ID=
