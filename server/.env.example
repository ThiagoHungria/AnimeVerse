# AnimeVerse — Backend (NestJS)
# Copy to .env and adjust values.
# cp .env.example .env

# PostgreSQL (matches docker-compose defaults)
DATABASE_URL=postgresql://animeverse:animeverse@localhost:5432/animeverse

# JWT access token — required; use a long random secret in production
JWT_ACCESS_SECRET=change-me-to-a-long-random-secret

# Access token lifetime (default: 15 minutes)
JWT_ACCESS_TTL=900s

# Refresh token lifetime (default: 7 days)
JWT_REFRESH_TTL=7d

# Google OAuth — required for POST /auth/google
# Must match NEXT_PUBLIC_GOOGLE_CLIENT_ID on the frontend
GOOGLE_CLIENT_ID=

# Allowed CORS origins (comma-separated)
CORS_ORIGINS=http://localhost:3000

# Redis — optional; falls back to in-memory cache when unset
REDIS_URL=redis://localhost:6379

# HTTP port (default: 3001)
PORT=3001

# Node environment
NODE_ENV=development
