# --- Server ---
PORT=3001
# Comma-separated list of allowed CORS origins (the Next.js frontend)
CORS_ORIGINS=http://localhost:3000

# --- Database (PostgreSQL) ---
# With docker-compose (see docker-compose.yml) this works out of the box:
DATABASE_URL="postgresql://animeverse:animeverse@localhost:5432/animeverse?schema=public"

# --- JWT ---
JWT_ACCESS_SECRET=change-me-access-secret
JWT_REFRESH_SECRET=change-me-refresh-secret
JWT_ACCESS_TTL=900s
JWT_REFRESH_TTL=7d

# --- Google OAuth (optional) ---
# GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com

# --- Redis (optional) ---
# If unset, an in-memory cache is used automatically.
# REDIS_URL=redis://localhost:6379
