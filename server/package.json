    "@types/node": "^26.0.1",
    "@types/passport-jwt": "^4.0.1",
    "prisma": "^6.19.3",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^6.0.3",
    "vitest": "^3.2.4"
