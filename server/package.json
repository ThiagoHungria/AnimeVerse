{
  "name": "animeverse-server",
  "version": "1.0.0",
  "description": "AnimeVerse backend — NestJS + Prisma + PostgreSQL recommendation API",
  "private": true,
  "scripts": {
    "test": "vitest run",
    "test:watch": "vitest",
    "build": "nest build",
    "start": "nest start",
    "start:dev": "nest start --watch",
    "start:prod": "node dist/main.js",
